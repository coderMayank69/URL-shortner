# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
# Replace YOUR_PG_PASSWORD with your PostgreSQL password (set during install)
DATABASE_URL="postgresql://postgres:YOUR_PG_PASSWORD@localhost:5432/urlshortener"

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
APP_URL=http://localhost:3000/
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────
# JWT  (generate a random secret: https://generate-secret.vercel.app/64)
# ─────────────────────────────────────────────
JWT_SECRET="thisisasecretkey-replace-in-production"
